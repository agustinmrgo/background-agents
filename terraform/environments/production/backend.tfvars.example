# Supabase Storage S3-compatible backend configuration for Terraform state.
# Copy this file to backend.tfvars and fill in your values.
# NEVER commit backend.tfvars to source control!
#
# Usage: terraform init -backend-config=backend.tfvars

# Generate these credentials in Supabase Dashboard:
# Storage → S3 Configuration → Access keys.
access_key = ""
secret_key = ""
region     = ""

# Official Supabase S3 endpoint shape:
# https://<project-ref>.storage.supabase.co/storage/v1/s3
endpoints = {
  s3 = "https://<project-ref>.storage.supabase.co/storage/v1/s3"
}

# Required for Supabase's path-style S3 endpoint.
use_path_style = true
